generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  password      String
  role          Role           @default(CLIENT)
  verification  String?        @default("PENDING")
  workload      Int            @default(0)
  orgId         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  auditProjects AuditProject[] @relation("AssignedAuditor")
  clientAudits  AuditProject[] @relation("ClientOwner")
  disputes      Dispute[]
  ratings       Rating[]
  scans         ScanRun[]
  transactions  Transaction[]
  organization  Organization?  @relation(fields: [orgId], references: [id])
  resetToken        String?   @unique
  resetTokenExpiry  DateTime?
}

model Organization {
  id           String           @id @default(cuid())
  name         String
  subscription SubscriptionTier @default(BASIC)
  createdAt    DateTime         @default(now())
  users        User[]
}

model ScanRun {
  id         String      @id @default(cuid())
  title      String
  url        String
  status     String?     @default("COMPLETED")
  score      Int?
  rawJson    Json?
  userId     String
  createdAt  DateTime    @default(now())
  disputes   Dispute[]
  issues     Issue[]
  scanIssues ScanIssue[]
  user       User        @relation(fields: [userId], references: [id])
}

model ScanIssue {
  id          String  @id @default(cuid())
  title       String
  description String
  severity    String
  wcagMapping String
  scanRunId   String
  scanRun     ScanRun @relation(fields: [scanRunId], references: [id], onDelete: Cascade)
}

model AuditProject {
  id        String      @id @default(cuid())
  domain    String
  status    AuditStatus @default(DRAFT)
  tier      SubscriptionTier
  auditorId String?
  clientId  String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  auditor   User?       @relation("AssignedAuditor", fields: [auditorId], references: [id])
  client    User?       @relation("ClientOwner", fields: [clientId], references: [id])
  issues    Issue[]
  report    Report?
  reviews   Review[]
}

model Issue {
  id             String        @id @default(cuid())
  title          String
  severity       String
  wcagMapping    String
  description    String
  recommendation String?
  isManual       Boolean       @default(false)
  scanRunId      String?
  auditProjectId String?
  issueType      String?       @default("Automated")
  evidence       Evidence[]
  auditProject   AuditProject? @relation(fields: [auditProjectId], references: [id], onDelete: Cascade)
  scanRun        ScanRun?      @relation(fields: [scanRunId], references: [id], onDelete: Cascade)
}

model Evidence {
  id          String @id @default(cuid())
  url         String
  description String
  issueId     String
  issue       Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
}

model Review {
  id             String       @id @default(cuid())
  notes          String
  status         String
  auditProjectId String
  createdAt      DateTime     @default(now())
  auditProject   AuditProject @relation(fields: [auditProjectId], references: [id])
}

model Report {
  id             String       @id @default(cuid())
  htmlContent    String
  pdfUrl         String?
  auditProjectId String       @unique
  createdAt      DateTime     @default(now())
  auditProject   AuditProject @relation(fields: [auditProjectId], references: [id])
}

model Transaction {
  id        String        @id @default(cuid())
  amount    Float
  currency  String        @default("USD")
  status    PaymentStatus @default(PENDING)
  stripeId  String?       @unique
  userId    String
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id])
}

model Dispute {
  id        String   @id @default(cuid())
  reason    String
  status    String   @default("OPEN")
  userId    String
  scanId    String?
  createdAt DateTime @default(now())
  scan      ScanRun? @relation(fields: [scanId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Rating {
  id      String  @id @default(cuid())
  score   Int
  comment String?
  userId  String
  user    User    @relation(fields: [userId], references: [id])
}

model SystemSettings {
  id             Int     @id @default(1)
  ngoDiscount    Float   @default(50.0)
  corporatePrice Float   @default(199.0)
  slaDays        Int     @default(3)
  qaThreshold    Int     @default(90)
  brandColor     String  @default("#2563eb")
  companyLogo    String?
  reportHeader   String  @default("Accessibility Audit Report")
  reportFooter   String  @default("Confidential - Pathfinder Platform")
  companyAddress String  @default("123 Tech Lane, Silicon Valley")
}

enum Role {
  CLIENT
  AUDITOR
  QA_ADMIN
  FOUNDER
}

enum AuditStatus {
  DRAFT
  IN_PROGRESS
  SUBMITTED_FOR_QA
  QA_RETURNED
  FOUNDER_APPROVED
  DELIVERED
}

enum SubscriptionTier {
  BASIC
  PRO
  ENTERPRISE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}
